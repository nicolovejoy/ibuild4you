# Firebase Configuration (ibuild4you-a0c4d project)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=ibuild4you.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=ibuild4you-a0c4d
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id

# Firebase Admin SDK (server-side only)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# AI Integration
ANTHROPIC_API_KEY=sk-ant-...

# AWS S3 (file uploads)
# Locally: SDK uses ~/.aws credentials. Only AWS_S3_BUCKET needed.
# Vercel: All four required.
AWS_S3_BUCKET=ibuild4you-files
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
